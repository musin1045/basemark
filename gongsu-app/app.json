{
  "expo": {
    "name": "gongsu-app",
    "slug": "gongsu-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#E6F4FE"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "notification": {
      "icon": "./assets/android-icon-monochrome.png",
      "color": "#185FA5"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "releaseChannel": "codex/gosu",
      "updateManifestUrl": "https://github.com/musin1045/basemark/raw/codex/gosu/gongsu-app/update-manifest.json",
      "privacyPolicyUrl": "https://github.com/musin1045/basemark/blob/codex/gosu/gongsu-app/privacy-policy.md"
    },
    "plugins": [
      "expo-sqlite",
      "expo-notifications"
    ]
  }
}
