{
  "expo": {
    "name": "\uACF5\uC218\uB85C",
    "slug": "gongsuro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#D6E4F4"
    },
    "ios": {
      "bundleIdentifier": "com.gongsuro.app",
      "supportsTablet": true
    },
    "android": {
      "package": "com.gongsuro.app",
      "adaptiveIcon": {
        "backgroundColor": "#0C447C",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      }
    },
    "notification": {
      "icon": "./assets/android-icon-monochrome.png",
      "color": "#0C447C"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "6f94c2c1-ba98-4072-92c4-686de8158879"
      },
      "releaseChannel": "codex/gosu",
      "updateManifestUrl": "https://github.com/musin1045/basemark/raw/main/gongsu-app/update-manifest.json",
      "privacyPolicyUrl": "https://github.com/musin1045/basemark/blob/main/gongsu-app/privacy-policy.md"
    },
    "plugins": [
      "expo-sqlite",
      "expo-notifications"
    ],
    "owner": "basemark"
  }
}
